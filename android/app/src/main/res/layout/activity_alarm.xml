<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:id="@+id/root_layout"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <!-- alarm / timer name — muted, letter-spaced, above the time -->
  <TextView
    android:id="@+id/alarm_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Alarm"
    android:textColor="#B3FFFFFF"
    android:textSize="15sp"
    android:letterSpacing="0.16"
    android:textAllCaps="true"
    app:layout_constraintBottom_toTopOf="@id/alarm_time"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_chainStyle="packed"
    app:layout_constraintVertical_bias="0.30" />

  <!-- large clock-style time display -->
  <TextView
    android:id="@+id/alarm_time"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="00:00"
    android:textColor="#FFFFFFFF"
    android:textSize="80sp"
    android:fontFamily="sans-serif-thin"
    android:layout_marginTop="8dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/alarm_title" />

  <!-- Dismiss — full width minus 40 dp margins; background set in code -->
  <Button
    android:id="@+id/btn_dismiss"
    android:layout_width="0dp"
    android:layout_height="56dp"
    android:text="Dismiss"
    android:textAllCaps="false"
    android:textSize="17sp"
    android:letterSpacing="0.03"
    android:textColor="#FFFFFFFF"
    android:stateListAnimator="@null"
    android:layout_marginStart="40dp"
    android:layout_marginEnd="40dp"
    android:layout_marginBottom="16dp"
    app:layout_constraintBottom_toTopOf="@id/btn_snooze"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent" />

  <!-- Snooze — narrower ghost pill; background set in code -->
  <Button
    android:id="@+id/btn_snooze"
    android:layout_width="0dp"
    android:layout_height="48dp"
    android:text="Snooze"
    android:textAllCaps="false"
    android:textSize="15sp"
    android:letterSpacing="0.03"
    android:textColor="#FFFFFFFF"
    android:stateListAnimator="@null"
    android:layout_marginStart="80dp"
    android:layout_marginEnd="80dp"
    android:layout_marginBottom="52dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

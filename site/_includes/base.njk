<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">

  {% set img = image or '/assets/logo.svg' %}
  {% set alt = image_alt or 'Noctua — open source app logo' %}

  <meta property="og:title" content="{{ title }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Noctua">
  <meta property="og:url" content="https://noctua.opennomad.com{{ page.url | url }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:image" content="https://noctua.opennomad.com{{ img }}">
  <meta property="og:image:alt" content="{{ alt }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@opennomad">
  <meta name="twitter:creator" content="@opennomad">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="https://noctua.opennomad.com{{ img }}">

  <link rel="icon" href="/assets/logo.svg" type="image/svg+xml">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d0d1a;
      --surface:   #1a1a2e;
      --border:    rgba(255,255,255,.08);
      --text:      #e8e8f0;
      --muted:     rgba(255,255,255,.5);
      --accent:    #7c6af7;
      --accent2:   #4fc3f7;
      --radius:    12px;
      --max-w:     900px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 1rem;
      line-height: 1.7;
    }

    .content-wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }

    .hero {
      text-align: center;
      padding: 5rem 1.5rem 3rem;
      max-width: var(--max-w);
      margin: 0 auto;
    }
    .hero img[alt*="logo"] { width: 96px; height: 96px; margin-bottom: 1.5rem; }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 200;
      letter-spacing: .15em;
      margin-bottom: .75rem;
    }
    .hero p { color: var(--muted); font-size: 1.1rem; max-width: 560px; margin: 0 auto 2rem; }
    .cta-row { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; align-items: flex-start; }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: .65rem 1.5rem;
      border-radius: var(--radius);
      font-size: .95rem;
      text-decoration: none;
      transition: opacity .15s;
      border: 1px solid transparent;
    }
    .btn:hover { opacity: .82; }
    .btn-primary  { background: var(--accent);  color: #fff; }
    .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
    .btn-icon { width: 1.1em; height: 1.1em; margin-right: .35em; }
    .btn-icon path { fill: currentColor; }
    .btn-blue { background: #1565C0; border-color: #1565C0; color: #fff; }
    .btn-purple { background: #6A1B9A; border-color: #6A1B9A; color: #fff; }
    .btn-green { background: #1B5E20; border-color: #1B5E20; color: #fff; }
    .btn-small { padding: .4rem .85rem; font-size: .85rem; }
    .download-group { display: flex; flex-direction: column; gap: .5rem; align-items: center; }
    .group-label { font-size: .85rem; color: var(--muted); font-weight: 500; }
    .src-note { font-size: .8em; opacity: .75; margin-left: .3em; }
    .ver-note { font-size: .8rem; color: var(--muted); }
    .support-links { margin-top: 1.5rem; }
    .made-by { font-size: .85rem; color: var(--muted); margin-top: .75rem; }
    .made-by a { color: var(--muted); }

    main { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem 6rem; }
    main h2 {
      font-size: 1.6rem; font-weight: 300; letter-spacing: .08em;
      margin: 3.5rem 0 1.5rem; padding-bottom: .5rem;
      border-bottom: 1px solid var(--border);
    }
    main h3 { font-size: 1.1rem; font-weight: 500; margin-bottom: .5rem; }
    main h4 { font-size: 1rem; font-weight: 600; color: var(--accent2); margin-bottom: .4rem; }
    main p  { margin-bottom: 1rem; color: var(--muted); }
    main a  { color: var(--accent2); }
    main hr { border: none; border-top: 1px solid var(--border); margin: 3rem 0; }
    main em { color: var(--muted); font-size: .9rem; }

    pre {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 1rem 1.25rem;
      overflow-x: auto; margin-bottom: 1.5rem;
    }
    code { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: .88rem; }
    p code, li code {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 4px; padding: .1em .35em; font-size: .85em;
    }

    table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: .9rem; }
    th { text-align: left; padding: .5rem .75rem; color: var(--muted); font-weight: 500; border-bottom: 1px solid var(--border); }
    td { padding: .5rem .75rem; border-bottom: 1px solid rgba(255,255,255,.04); }

    .screen-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem; margin-bottom: 1.5rem;
    }
    .screen-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow: hidden;
    }
    .screen-card h3 { margin-bottom: .75rem; }
    .screen-card img {
      width: 100%; border-radius: 8px; background: rgba(255,255,255,.04);
      margin-bottom: .75rem; display: block;
    }
    .screen-card p { font-size: .9rem; margin-bottom: 0; }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.25rem; margin-bottom: 1.5rem;
    }
    .feature {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
    }
    .feature p { font-size: .92rem; margin-bottom: 0; }

    .screen > p > img {
      width: 100%; border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface);
      aspect-ratio: 16/9; object-fit: cover;
      margin-bottom: .5rem; display: block;
    }

    footer {
      text-align: center; padding: 2rem;
      color: var(--muted); font-size: .85rem;
      border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>
  <main>{{ content | safe }}</main>
  <footer>Noctua &mdash; open source, MIT licence</footer>
</body>
</html>